<rdf:Description rdf:about="http://data.europa.eu/c4p/data/382194467630">
	<rdf:type rdf:resource="http://www.w3.org/2008/05/skos-xl#Label"/>
	<created xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-07-16</created>
	<literalForm xmlns="http://www.w3.org/2008/05/skos-xl#" xml:lang="en">Suggestions list</literalForm>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_16">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-02</modified>
	<rdf:value xml:lang="en">Use the term “mental illness” instead of “insane” or “mentally deranged,” except in a quote or when referring to a criminal defense.</rdf:value>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_112_en">
	<hasSuggestedTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/a_6_en"/>
	<hasSuggestedTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/a_5_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/a_5_en">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestedTerm"/>
	<literalForm xmlns="http://www.w3.org/2008/05/skos-xl#" xml:lang="en">Asian</literalForm>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/a_31_en">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestedTerm"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<literalForm xmlns="http://www.w3.org/2008/05/skos-xl#" xml:lang="en">Black</literalForm>
	<note xmlns="http://www.w3.org/2004/02/skos/core#" xml:lang="en">When used as an adjective.</note>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_80">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-12</modified>
	<created xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-12</created>
	<rdf:value xml:lang="en">The term should also be avoided in quotations or be  preceded by a trigger warning, for example: “We are showcasing an archival object that contains racist terms. These may be hurtful or re-traumatising.”</rdf:value>
	<rdf:value xml:lang="de">Auch in Zitaten sollte darauf verzichtet werden oder eine Triggerwarnung vorangestellt werden, beispielsweise: “Wir zeigen ein Archiv-Stück, in dem rassistische Begriffe vorkommen. Sie können verletzend oder retraumatisierend sein”.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_48_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_49_de"/>
</rdf:Description>

