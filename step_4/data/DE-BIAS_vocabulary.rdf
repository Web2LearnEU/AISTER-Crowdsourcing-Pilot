<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_14_fr">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_6"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_2"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_3"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_23_fr"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_24_fr"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="fr">Terme injurieux et raciste pour désigner un individu ou un groupe de personnes de couleur noire : Tribus nègres. Le mot nègre ayant souvent été employé dans des contextes discriminatoires ou racistes, on lui préfère aujourd'hui des équivalents neutres : dans tous les registres, noir, nom et adjectif (un Noir, une Noire, les Noirs ; la musique noire américaine) ;</description>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“nègre,” in Dictionnaire De Français Larousse, n.d., accessed April 3, 2024, https://www.larousse.fr/dictionnaires/francais/n%C3%A8gre/54086.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="fr">Nègre / Négresse</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0006"/>
	<topConceptOf xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
	<topConceptOf xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0006"/>
	<hasSuggestedTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/a_26_fr"/>
	<hasSuggestedTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/a_27_fr"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_55_nl">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_11"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_7"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_57_nl"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="nl">Verouderd woord voor homoseksueel.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-20</modified>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“Woordenlijst Inclusief Taalgebruik,” vrt Diversiteit &amp; Inclusie, n.d., accessed April 2, 2024, https://diversewoordenlijstvrt.wordpress.com/2023/02/10/homofiel/.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="nl">Homofiel</title>
