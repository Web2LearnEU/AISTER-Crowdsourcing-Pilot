	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_71_fr"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="fr">Terme raciste. (Vieux) Né d'un Blanc et d'une Noire, ou d'un Noir et d'une Blanche.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-09-12</modified>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“mulâtre,” in Dictionnaire De Français Larousse, n.d., accessed September 12, 2025, https://www.larousse.fr/dictionnaires/francais/mul%C3%A2tre/53131.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="fr">Mulâtre</title>
