	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_199_en"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="en">Derogatory word used for all Latinos. Highly pejorative, offensive term. The word is a racial slur.</description>
