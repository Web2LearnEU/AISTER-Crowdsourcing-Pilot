	<altLabel xmlns="http://www.w3.org/2008/05/skos-xl#" rdf:resource="http://data.europa.eu/c4p/data/xl_nl_4305d563"/>
	<altLabel xmlns="http://www.w3.org/2008/05/skos-xl#" rdf:resource="http://data.europa.eu/c4p/data/xl_de_3d120d6a"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/cat_1">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="de">Achse der einteilung von Personen in Kinder, Jugendliche, Erwachsene, mittleres Alter und Alter, wobei das Erwachsenenalter die Norm darstellt.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="en">Axis of classification of persons according to a division from child to adolescent, adult, middle age and old age, with adulthood as the norm.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="it">Classificazione delle persone secondo una divisione da bambino ad adolescente, adulto, mezza età e vecchiaia, con l'età adulta come norma.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="fr">Axe de classification des personnes selon une division allant de l'enfant à l'adolescent, à l'adulte, à l'âge moyen et à la vieillesse, l'âge adulte étant la norme.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="nl">Classificatie van personen volgens een indeling van kind naar adolescent, volwassene, middelbare leeftijd en ouderdom, met volwassenheid als norm.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-04</modified>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/categories"/>
