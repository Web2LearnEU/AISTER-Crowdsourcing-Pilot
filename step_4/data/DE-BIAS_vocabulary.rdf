<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_38_fr">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_61_fr"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="fr">Terme injurieux du temps colonial pour décrire un homme à la peau noire, originaire d'Afrique. Provient de « Banania », une marque de chocolat en poudre destinée au petit déjeuner, dont les boîtes étaient illustrées par un visuel représentant un tirailleur sénégalais.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-13</modified>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“Banania” in La Langue Française n. d., accessed April 3, 2024, https://www.lalanguefrancaise.com/dictionnaire/definition/banania.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="fr">Banania</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
