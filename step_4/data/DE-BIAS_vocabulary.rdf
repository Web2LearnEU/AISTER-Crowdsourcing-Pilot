	<description xmlns="http://purl.org/dc/terms/" xml:lang="fr">Terme injurieux et raciste pour désigner des personnes d'origine italienne.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-13</modified>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“Rital” in Dico en Ligne Le Robert n. d., accessed April 3, 2024, https://dictionnaire.lerobert.com/definition/rital.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="fr">Rital</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
