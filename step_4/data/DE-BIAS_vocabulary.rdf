<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_25_it">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_11"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_33_it"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_34_it"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="it">Come aggettivo o sostantivo, indica una persona con braccia o gambe deformate o storte, generalmente a causa di malformazioni congenite o traumi subiti.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-20</modified>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“Storpio,” in Dizionario Tullio De Mauro, n.d., accessed April 2, 2024, https://dizionario.internazionale.it/parola/storpio/.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="it">Storpio / Storpia</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
