</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_127_en">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_3"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_1"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_187_en"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="en">Refers to a dirty, shabbily-dressed child.</description>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">Cultural Heritage Terminology Network, “Inclusive Terminology Glossary. 5. Working Class History,” 2024, accessed April 3, 2024, https://docs.google.com/document/d/1dz6XNaJbO1v85OAlCeyL6HXO27__S7e3jOnC8YG-8Zo/edit.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="en">Ragamuffin</title>
