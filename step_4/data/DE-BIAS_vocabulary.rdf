<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_128_nl">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_6"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_2"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_143_nl"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="nl">Koloniale onomatopee gebruikt voor Afrikaanse slaginstrument dat beter aangeduid wordt met de lokale benaming of meer neutrale of algemene termen als 'spleettrommel'</description>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="nl">Tamtam</title>
