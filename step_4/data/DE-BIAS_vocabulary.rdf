<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_153_en">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_11"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_7"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_219_en"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="en">A woman who engages in sexual activity in return for payment, esp. as a means of livelihood; a female prostitute.</description>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">Oxford English Dictionary. “Whore“. Accessed May 2, 2024. https://www.oed.com/dictionary/whore_n?tab=meaning_and_use#14422151</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="en">Whore</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
