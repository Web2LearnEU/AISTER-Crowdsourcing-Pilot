<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_107_nl">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_10"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_117_nl"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_115_nl"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="nl">Een historische, pejoratieve term gebruikt om een Rooms-katholieke priester of katholieke christenen in het algemeen aan te duiden. Ontstaan tijdens de religieuze conflicten tussen protestanten en katholieken in de zestiende en zeventiende eeuw.</description>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="nl">Paaps / Papist</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
