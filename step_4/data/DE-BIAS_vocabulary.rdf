<rdf:Description rdf:about="http://data.europa.eu/c4p/data/cat_14">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="en">The representation of historical periods and the distinction between modernity and primitivism.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="de">Die Darstellung historischer Epochen und die Unterscheidung zwischen Modernität und Primitivismus.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="it">La rappresentazione dei periodi storici e la distinzione tra modernità e primitivismo.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="nl">De representatie van historische perioden en het onderscheid tussen moderniteit en primitivisme.</description>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="fr">La représentation des périodes historiques et la distinction entre modernité et primitivisme.</description>
