	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_157_nl"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_70_it"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_12_it"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_84_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_48_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_39_nl"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_122_nl"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_17_nl"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_66_nl"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_49">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-11</modified>
	<rdf:value xml:lang="en">This term can be used if it refers to animals. The use when referring to people is inappropriate.</rdf:value>
	<rdf:value xml:lang="de">Im Zusammenhang mit Tieren ist dieser Begriff angemessen, er sollte jedoch bezogen auf Menschen nicht genutzt werden.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_64_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_27_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_163_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_211_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_233_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_52">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">As a term for people of short stature, the term is discriminatory and should be avoided. It can be used to describe fictional or fairy tale characters.</rdf:value>
	<rdf:value xml:lang="de">Als Bezeichnung für kleinwüchsige Menschen ist der Begriff diskriminierend und sollte unbedingt vermieden werden. Zur Beschreibung der fiktiven oder Märchen-Figur kann er verwendet werden.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_113_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_112_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_159_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_158_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_64">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">The use of quotation marks is advised regardless of the context.</rdf:value>
	<rdf:value xml:lang="de">Unabhängig vom Kontext sollte der Begriff in Anführungszeichen gesetzt werden.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_124_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_127_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_128_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_44">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-11</modified>
	<rdf:value xml:lang="en">The use of quotation marks is advised when referring to people.</rdf:value>
	<rdf:value xml:lang="de">Bei Verwendung in Bezug auf Menschen in Anführungszeichen setzen.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_27_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_46">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">The saying is strongly associated with memories of Nazi concentration camps, so it should only be used in this context.</rdf:value>
	<rdf:value xml:lang="de">Der Spruch ist stark mit der Erinnerung an die NS-Konzentrationslager verbunden, dass er nur in diesem Zusammenhang verwendet werden sollte.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_42_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_41_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_78">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Non-members of the Jewish community should not use the term.</rdf:value>
	<rdf:value xml:lang="de">Nicht-Angehörige der jüdischen Community sollten den Begriff nicht verwenden.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_1_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_79">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">The antisemitic term is derogatory or offensive, and its use is strongly discouraged.</rdf:value>
	<rdf:value xml:lang="de">Der antisemitische Begriff ist abwertend oder verletzend, vom Gebrauch dieses Begriffs wird unbedingt abgeraten.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_20_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_51">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-01</modified>
	<rdf:value xml:lang="en">Bear in mind the difference between official sign languages used by people with hearing impairments and spontaneous gestures or situational signs used by hearing people. For example, traders on the stock exchange have developed their own sign language to attract attention amid the noise of the trading floor.</rdf:value>
	<rdf:value xml:lang="de">Die Sprache, die von Menschen ohne Hörvermogen verwendet wird, wird als Gebärdensprache bezeichnet. Der Begriff Zeichensprache sollte nur im Hinblick auf spontanen Gesten oder situativen Zeichen Hörender verwendet werden. So haben z.B. die Händler*innen an der Börse eine eigene Zeichensprache entwickelt, um im Lärm des Börsenquartetts auf sich aufmerksam zu machen.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_92_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_42">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-10</modified>
	<rdf:value xml:lang="en">This term can be used in relation to animals or plants, but should be avoided when referring to people or other cultures.</rdf:value>
	<rdf:value xml:lang="de">Im Zusammenhang mit Tieren oder Pflanzen ist dieser Begriff angemessen, im Bezug auf Menschen oder andere Kulturen sollte er vermieden werden.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_23_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_161_de"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_160_de"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_37">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-02-21</modified>
	<rdf:value xml:lang="de">Der Begriff kann nur zur Beschreibung verwendet werden, wenn sich eine Person selbst so bezeichnet.</rdf:value>
	<rdf:value xml:lang="en">Only use to describe people who self-identify with the term.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_77_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_206_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_205_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_11">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">This term can only be used if it refers to animals.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_13_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_195_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_95_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_156_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_37_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_176_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_38_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_167_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_11_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_5">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-05</modified>
	<rdf:value xml:lang="fr">Actuellement, il n'existe pas de consensus sur un terme alternatif approprié.</rdf:value>
	<rdf:value xml:lang="nl">Er is geen consensus over alternatieve terminologie.</rdf:value>
	<rdf:value xml:lang="en">Currently, no consensus exists with regard to an appropriate alternative term.</rdf:value>
	<rdf:value xml:lang="it">Al momento non c'è consenso unanime relativamente a un'alternativa adeguata.</rdf:value>
	<rdf:value xml:lang="de">Derzeit besteht kein Konsens über einen geeigneten alternativen Begriff.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_135_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_134_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_1_fr"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_2_fr"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_126_nl"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_29">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">The term should not be confused with ‘race’.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_82_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_10">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-02</modified>
	<rdf:value xml:lang="en">Always honour a person’s self-identity and be specific, when appropriate i.e Person of [x] and [x] heritage. The order in which an individual lists their ethnic identities may be important to them. Do not use word like ‘half’ or ‘quarter’ to describe someone’s ethnic heritage.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_61_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_126_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_62_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_127_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_161_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_152_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_207_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_209_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_162_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_151_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_166_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_116_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_20_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_117_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_21_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_149_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_102_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_150_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_104_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_101_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_182_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_103_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_105_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_30">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">There is no easy alternative for this term. The term is used by some in quotation marks to acknowledge the controversy surrounding the term. Racism is a valid term to use, as it acknowledges the discriminatory practices of racial thinking.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_185_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_65">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-11</modified>
	<topConceptOf xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/suggestions"/>
	<rdf:value xml:lang="nl">De term kan worden gebruikt als het gaat om objecten, dieren of planten; het gebruik als het gaat om mensen wordt afgeraden.</rdf:value>
	<rdf:value xml:lang="en">Use with caution in relation to humans. When referring to animals, plants or things the usage of the term is unproblematic.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_22_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_24_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_23_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_23_nl"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_49_nl"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_164_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_82_nl"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_12">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">When possible, refer to a person’s specific condition. Regulations or places like “handicapped parking” are generally acceptable. However, it’s more preferred to use the terms like “accessible parking.”</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_106_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_66">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">When possible, refer to a person’s specific condition. When describing individuals, do not reference disabilities unless it is relevant to the context.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_71_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_26">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">This term is not recommended for use in contemporary context. Specify region or nation of origin when possible to avoid the impression that all people of African descent have the same cultural background, family history, or family experiences. Note that 'Black' is appropriate rather than 'African American' to describe people of African descent from various national origins (e.g., Haitian, Nigerian).</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_165_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_17">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="de">Der verwandte Begriff “Kaffir” ist dann angemessen, wenn er sich auf die srilankischen Ethnie bezieht, da es sich um einen Begriff handelt, mit dem sich die Gruppe selbst identifiziert.</rdf:value>
	<rdf:value xml:lang="en">Only appropriate when used to refer to the Sri Lankan Kaffirs, as it is a term with which the group self-identifies.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_136_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_32">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Generally, it is not considered problematic if people choose to speak of roots when referring to themselves. Some people, however, experience it as an intrusion. It might be more useful to refer to routes (the cultural and social biopgraphy of people).</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_189_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_76">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">If the term is not used as a personal name, it is highly inappropriate and offensive and should not be used.</rdf:value>
	<rdf:value xml:lang="nl">Als de term niet als persoonsnaam wordt gebruikt, is hij hoogst ongepast en beledigend. In dat geval raden wij elk gebruik af.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_71_nl"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_54">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Use in a strict sense and not generically.</rdf:value>
	<rdf:value xml:lang="it">Da utilizzare in senso stretto e non generico</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_3_it"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_4_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_14">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-02</modified>
	<rdf:value xml:lang="en">There is no consensus on the use of the term. In the U.S., “American Indian” has a complicated history but is still used for self-identification by some individuals and communities, as well as by the U.S. and Canadian Federal Governments. In Spanish-speaking Central and South America, “indio” is generally seen as problematic and rarely used by Indigenous people. In Brazil, however, “índio” is less contested and more commonly accepted.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_122_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_56">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-20</modified>
	<rdf:value xml:lang="en">Do not use in a generalised manner, but only in its purely geographical sense, i.e. if it actually corresponds to the nationality of the subject.</rdf:value>
	<rdf:value xml:lang="it">Non utilizzare in modo generalizzato ma unicamente nella sua accezione puramente geografica, quindi se effettivamente corrisponde alla nazionalità del soggetto.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_6_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_18">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-02</modified>
	<rdf:value xml:lang="en">‘Hispanic’, ‘Latino’ and ‘Latinx’ have different connotations. Ideally, use the term that a person self-identifies with. Be mindful that some prefer to identify themselves as ‘Hispanic,’ while others call themselves ‘Latino’. In general, naming a nation or region of origin is preferred (e.g., Bolivian, Salvadoran, or Costa Rican).</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_141_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_110_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_140_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_57">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-20</modified>
	<rdf:value xml:lang="en">The term no longer used by scholars.</rdf:value>
	<rdf:value xml:lang="it">Termine desueto tra gli studiosi</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_11_it"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_10_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_28">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">The term is not recommended for use. The term can be used in a descriptive or historical context, in which case the use of quotation marks is suggested. For example: There was an artistic movement called ‘primitivism’.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_177_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_69">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Usually more useful when describing large, diverse groups of people than individuals.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_161_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_162_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_20_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_21_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_24">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-02</modified>
	<rdf:value xml:lang="en">Phrases like ‘was the first European to reach…’ would be more appropriate.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_73_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_72_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_40">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-04</modified>
	<rdf:value xml:lang="en">Be as specific as possible in terms of country, population etc. If the term is used to contrast the western part of a country or region with the eastern part, it is acceptable.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_214_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_13">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">To avoid stigmatization of non-heterosexual identities and to do justice to the plurality of sexual diversity, using community-derived descriptors like ‘lesbian,’ ‘gay’ and ‘bisexual’ is preferred. Choose culturally specific names such as Two-Spirit.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_112_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_58">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">The term ‘First Nations’ applies to both registered and non-registered Indienous people, so it is important to use it correctly, especially when referring to programmes specifically targeting registered persons. Similarly, caution should be exercised when using this term, as many First Nations have publicly and politically expressed their preference for the term “Indigenous people”.</rdf:value>
	<rdf:value xml:lang="fr">Le terme « Premières Nations » s’applique aux Indiens inscrits et non inscrits, de sorte qu’il est important de bien l’utiliser, surtout si l’on fait référence à des programmes visant particulièrement les Indiens inscrits. De même, la prudence est donc de mise lorsque l’on utilise ce terme, car de nombreuses Premières Nations ont exprimé publiquement et politiquement qu’elles aimaient mieux le terme « Autochtone ».</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_33_fr"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_7_fr"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_19">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">Generally acceptable to use the term. In the context of Suriname, however, it is better to use the specific names for each Maroon group: such as Saamaka, Matawai, Aluku, Kwinti, Paamaka.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_143_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_38">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">In general, ‘Roma’ can be used. Groups and subgroups, however, have their own preferred names (e.g., Sinti) so it is advised to use these when known.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_99_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_63">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Applicable only in a medical diagnosis.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_76_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_77">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">This term may be used when referring to objects; its use when referring to people is discouraged.</rdf:value>
	<rdf:value xml:lang="nl">Deze term kan worden gebruikt als het gaat om objecten; het gebruik als het gaat om mensen wordt afgeraden.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_60_nl"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_19_nl"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_68">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Use with caution in the context of people. Unproblematic when referring to the general aspect or character of something.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_50_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_36">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">Use terms and pronouns that people find acceptable and respectful for describing themselves.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_184_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_204_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_73">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">When referring to a person with a physical disability, and it is necessary to also report specific information about the disability, it is sufficient to use the definition “person with a physical or motor disability”.</rdf:value>
	<rdf:value xml:lang="it">Se si fa riferimento a una persona con disabilità fisica, ed è necessario riportare anche le informazioni specifiche sulla condizione di disabilità, è sufficiente limitarsi a utilizzare la definizione “persona con disabilità fisica o motoria”.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_82_it"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_79_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_35">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-02</modified>
	<rdf:value xml:lang="en">When writing about traditions, or objects understood by their makers to represent traditions or traditional styles, be as specific as possible about time, place and intention. For example: “In the 18th century people used this, in 2018 they use that….” In some cases the term can be replaced with “historic.”</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_203_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_75">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Use with caution in the context of people. The term is unproblematic when it refers specifically to people from the Caucasus region.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_36_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_34">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">‘Developing nations’ as well as ‘low-income countries’ have been suggested as alternatives. These terms, however, are also contested, for the same reasons as ‘Third World’. It is preferable to name the countries and thus be as specific as possible.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_202_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_72">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Terms with a neutral meaning should be preferred instead.</rdf:value>
	<rdf:value xml:lang="it">Preferire termini dotati di una accezione neutra.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_70_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_59">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">Avoid referring to an individual as a paraplegic. Instead, say the person has paraplegia. Sometimes people with paraplegia refer to themselves as a “para.” In those cases, use the word in quotes.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_171_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_71">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-05</modified>
	<rdf:value xml:lang="en">It is advisable to ask the person how they would prefer to be described.</rdf:value>
	<rdf:value xml:lang="it">È opportuno chiedere alla persona come preferisce essere descritta.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_69_it"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_81_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_74">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-05</modified>
	<rdf:value xml:lang="en">It is preferable to use the noun instead of the adjective.</rdf:value>
	<rdf:value xml:lang="it">È opportuno preferire la parola “sordità” piuttosto che usare “sordo” come aggettivo.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_81_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_22">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-02</modified>
	<rdf:value xml:lang="en">When it is necessary to compare a dominant racial group with a nondominant racial group, use a modifier like ‘racial,’ ‘ethnic,’ or ‘racial-ethnic.’ Otherwise, other terms may be preferred, such as ‘people of color‘ to refer to non-White racial and ethnic groups or more generally, ‘underrepresented people.’</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_146_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_25">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">Refer specifically to the physical changes.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_74_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_70">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">The term “enslaved person” emphasizes an individual's humanity within a slaveholding society, highlighting that their identity centers on personhood while acknowledging they were forcibly subjected to slavery by others.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_198_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_67">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Choose a term that fits the specific context, avoiding language that implies a hierarchy of value or progress.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_90_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_33">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Use the person’s name if known. The use of “servant” can be a transparent representation of power relation. Maintaining the term in object descriptions may be recommended in some situations, especially when the person’s name is not known, since it conveys power relations transparently.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_193_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_60">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Refer to someone as having dementia only if the information is relevant and you are confident there is a medical diagnosis. When possible, reference the specific disease, such as ‘someone with Huntington’s disease.’</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_235_en"/>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_192_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_55">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-08</modified>
	<rdf:value xml:lang="en">It would be preferable not to use it, as it risks assigning a label that becomes permanent even when the admission period is long over. The term depersonalises and nullifies people’s identities.</rdf:value>
	<rdf:value xml:lang="it">Sarebbe preferibile non utilizzarlo in quanto rischia di attribuire un'etichetta che diviene permanente anche quando ormai la fase di ingresso è del tutto superata. Il termine spersonalizza e annulla l’identità delle persone.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_5_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_53">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">There are several possible alternatives. The term can be replaced with generic terms such as “non-EU citizen”, “foreign national”. However, when referring to refugees, asylum seekers or beneficiaries of international protection, it is necessary to be precise and define them by their status.</rdf:value>
	<rdf:value xml:lang="it">Le alternative possibili sono diverse. Si può sostituire extracomunitario con termini generici come ‘non comunitario’, ‘cittadino straniero’. Tuttavia, quando si tratta di rifugiati, richiedenti asilo o beneficiari di una forma di protezione internazionale, occorre essere precisi e definirli con il loro status.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_2_it"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_39">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-11-07</modified>
	<rdf:value xml:lang="en">When the people themselves find it an acceptable and respectful term for describing themselves, it is appropriate. It can be used in the context of fashion and popular culture, but only when referring to oneself.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_208_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/s_20">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#SuggestionNote"/>
	<rdf:value xml:lang="en">Where known use the term that the group to which the traditional healer belongs regard as acceptable and respectful.</rdf:value>
	<suggestionNoteFor xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_144_en"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/t_118_en">
	<rdf:type rdf:resource="http://data.europa.eu/c4p/ontology#ContentiousTerm"/>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-04</modified>
	<hasSuggestionNote xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/s_3"/>
	<isAmbiguous xmlns="http://data.europa.eu/c4p/ontology#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isAmbiguous>
	<literalForm xmlns="http://www.w3.org/2008/05/skos-xl#" xml:lang="en">Illegal</literalForm>
	<deprecated xmlns="http://www.w3.org/2002/07/owl#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</deprecated>
	<editorialNote xmlns="http://www.w3.org/2004/02/skos/core#" xml:lang="en">This term is used in a contentious as well as non-contentious way and should not be flagged in all cases to avoid false positives.</editorialNote>
</rdf:Description>

