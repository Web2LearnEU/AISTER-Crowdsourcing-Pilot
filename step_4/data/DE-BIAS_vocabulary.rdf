<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_45_it">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_58_it"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="it">Questo termine, originariamente utilizzato per descrivere un animale morto e in decomposizione, viene talvolta usato in senso figurato per indicare una persona spregevole, vile o meschina. La parola ha un'accezione molto negativa e viene utilizzata per esprimere disprezzo nei confronti di qualcuno.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-20</modified>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“carogna,” in Dizionario Tullio De Mauro, n.d., accessed April 3, 2024, https://dizionario.internazionale.it/parola/carogna.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="it">Carogna</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
