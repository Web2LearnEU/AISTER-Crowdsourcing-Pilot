	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_5"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_3"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_81_nl"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="nl">Laaggeschoold is verouderd, en heet officieel 'kortgeschoold'. In administratief jargon uit de werksfeer wordt dat soms ook 'een grote afstand tot de arbeidsmarkt'.</description>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“Woordenlijst Inclusief Taalgebruik,” vrt Diversiteit &amp; Inclusie, n.d., accessed April 2, 2024, https://diversewoordenlijstvrt.wordpress.com/.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="nl">Laaggeschoold</title>
