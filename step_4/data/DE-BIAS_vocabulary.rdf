<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_176_en">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_6"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_9"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_233_en"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="en">This term has long been used to dehumanize and harm Native Americans and Indigenous people, labeling them as uncivilized or primitive. </description>
