	<closeMatch xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="https://w3id.org/culco/wordsmatter/102"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/c_105_nl">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_5"/>
	<hasBiasCategory xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/cat_1"/>
	<hasContentiousTerm xmlns="http://data.europa.eu/c4p/ontology#" rdf:resource="http://data.europa.eu/c4p/data/t_113_nl"/>
	<description xmlns="http://purl.org/dc/terms/" xml:lang="nl">Een voorbijgestreefde term, tenzij misschien in een historische of religieuze context. Deze term kan bijvoorbeeld wel worden gebruikt in de context van de Protestantse Kerk in Nederland.</description>
	<modified xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-01</modified>
	<source xmlns="http://purl.org/dc/terms/" xml:lang="en">“Woordenlijst Inclusief Taalgebruik,” vrt Diversiteit &amp; Inclusie, n.d., accessed April 2, 2024, https://diversewoordenlijstvrt.wordpress.com/2023/01/23/ouderling/.</source>
	<title xmlns="http://purl.org/dc/terms/" xml:lang="nl">Ouderling</title>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
	<inScheme xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0005"/>
	<topConceptOf xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0001"/>
	<topConceptOf xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="http://data.europa.eu/c4p/data/0005"/>
