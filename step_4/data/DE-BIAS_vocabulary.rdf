	<closeMatch xmlns="http://www.w3.org/2004/02/skos/core#" rdf:resource="https://w3id.org/culco/wordsmatter/103_nl"/>
</rdf:Description>

<rdf:Description rdf:about="http://data.europa.eu/c4p/data/0005">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
